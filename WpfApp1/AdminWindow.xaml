<Window x:Class="WpfApp1.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Admin Portal - My Praises &amp; Earnings" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#2C3E50">
    
    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5"
                                BorderThickness="1"
                                BorderBrush="#2980B9">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="PraiseCard" TargetType="Border">
            <Setter Property="Background" Value="#34495E"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#4A5F7A"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#1A252F" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="💰 Admin Portal - My Praises &amp; Earnings" 
                              FontSize="28" 
                              FontWeight="Bold" 
                              Foreground="#F39C12"/>
                    <TextBlock Text="View all praises and track your earnings" 
                              FontSize="14" 
                              Foreground="#BDC3C7"
                              Margin="0,5,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="BtnLogout" 
                            Content="🚪 Logout" 
                            Style="{StaticResource ModernButton}"
                            Background="#E74C3C"
                            Padding="15,8"
                            FontSize="12"
                            Click="BtnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Statistics Dashboard -->
        <Border Grid.Row="1" Background="#34495E" Padding="20" Margin="20,10,20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="💰 Total Earned" 
                              FontSize="16" 
                              FontWeight="Bold" 
                              Foreground="#27AE60"
                              HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalEarned" 
                              Text="$0.00" 
                              FontSize="24" 
                              FontWeight="Bold" 
                              Foreground="White"
                              HorizontalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="📝 Total Praises" 
                              FontSize="16" 
                              FontWeight="Bold" 
                              Foreground="#3498DB"
                              HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalPraises" 
                              Text="0" 
                              FontSize="24" 
                              FontWeight="Bold" 
                              Foreground="White"
                              HorizontalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="👑 Elite Praises" 
                              FontSize="16" 
                              FontWeight="Bold" 
                              Foreground="#F39C12"
                              HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtElitePraises" 
                              Text="0" 
                              FontSize="24" 
                              FontWeight="Bold" 
                              Foreground="White"
                              HorizontalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="⭐ Premium Praises" 
                              FontSize="16" 
                              FontWeight="Bold" 
                              Foreground="#9B59B6"
                              HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtPremiumPraises" 
                              Text="0" 
                              FontSize="24" 
                              FontWeight="Bold" 
                              Foreground="White"
                              HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Praises List -->
        <Grid Grid.Row="2" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="All Praises" 
                          FontSize="20" 
                          FontWeight="Bold" 
                          Foreground="White"
                          VerticalAlignment="Center"/>
                <Button x:Name="BtnRefresh" 
                        Content="🔄 Refresh" 
                        Style="{StaticResource ModernButton}"
                        Background="#27AE60"
                        Margin="20,0,0,0"
                        Click="BtnRefresh_Click"/>
                <Button x:Name="BtnExport" 
                        Content="📊 Export Data" 
                        Style="{StaticResource ModernButton}"
                        Background="#E67E22"
                        Margin="10,0,0,0"
                        Click="BtnExport_Click"/>
            </StackPanel>
            
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="PraisesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource PraiseCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Level}" 
                                                      FontWeight="Bold" 
                                                      Foreground="#F39C12"
                                                      FontSize="16"/>
                                            <TextBlock Text=" - $" 
                                                      Foreground="#27AE60"
                                                      FontSize="14"
                                                      Margin="5,0,0,0"/>
                                            <TextBlock Text="{Binding Amount, StringFormat=F2}" 
                                                      Foreground="#27AE60"
                                                      FontSize="14"
                                                      FontWeight="Bold"/>
                                        </StackPanel>
                                        
                                        <TextBlock Text="From: " 
                                                  Foreground="#BDC3C7" 
                                                  FontSize="12"/>
                                        <TextBlock Text="{Binding Name}" 
                                                  Foreground="#3498DB" 
                                                  FontSize="12"
                                                  FontWeight="Bold"/>
                                        
                                        <TextBlock Text="Message:" 
                                                  Foreground="#BDC3C7" 
                                                  FontSize="12"
                                                  Margin="0,5,0,2"/>
                                        <TextBlock Text="{Binding Message}" 
                                                  Foreground="White"
                                                  TextWrapping="Wrap"
                                                  FontSize="14"/>
                                        
                                        <TextBlock Text="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}" 
                                                  Foreground="#7F8C8D" 
                                                  FontSize="10"
                                                  Margin="0,5,0,0"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" 
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Emoji}" 
                                                  FontSize="24"
                                                  HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
        
        <!-- Footer -->
        <Border Grid.Row="3" Background="#1A252F" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnBackToMain" 
                        Content="🔙 Back to Main Portal" 
                        Style="{StaticResource ModernButton}"
                        Background="#E74C3C"
                        Click="BtnBackToMain_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
